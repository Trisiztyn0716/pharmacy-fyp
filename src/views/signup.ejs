<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="auth-page">
  <main class="signup-shell">
    <section class="card signup-card">
      <a href="/login?role=<%= role %>" class="back-link">&larr; Back to login</a>
      <p class="eyebrow">Create Account</p>
      <h1><%= role === "staff" ? "Staff sign up" : "Basic user sign up" %></h1>

      <nav class="role-switch" aria-label="Choose account type">
        <a class="<%= role === 'customer' ? 'active' : '' %>" href="/signup?role=customer">Basic User</a>
        <a class="<%= role === 'staff' ? 'active' : '' %>" href="/signup?role=staff">Staff</a>
      </nav>

      <% if (role === "staff") { %>
        <div class="verification-info">
          <strong>Staff email verification required</strong>
          <p>We will send a six-digit verification code to your email address before a staff account is created.</p>
        </div>
      <% } %>

      <% if (error) { %>
        <p class="error login-error"><%= error %></p>
      <% } %>

      <form action="/signup/<%= role %>" method="POST" class="form login-form">
        <label for="full-name">Full name</label>
        <input id="full-name" name="full_name" value="<%= fullName %>" autocomplete="name" required>

        <label for="email">Email address</label>
        <input id="email" type="email" name="email" value="<%= email %>" autocomplete="email" required>

        <label for="password">Password</label>
        <input id="password" type="password" name="password" minlength="8" autocomplete="new-password" required>

        <label for="confirm-password">Confirm password</label>
        <input id="confirm-password" type="password" name="confirm_password" minlength="8" autocomplete="new-password" required>

        <button type="submit">
          <%= role === "staff" ? "Send Verification Code" : "Create Basic User Account" %>
        </button>
      </form>
    </section>
  </main>
</body>
</html>
