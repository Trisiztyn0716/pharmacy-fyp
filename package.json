{
  "name": "pharmacy-mvc-dailymed-starter",
  "version": "1.0.0",
  "description": "MVC pharmacy management starter with PostgreSQL and DailyMed medicine information API cache.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "psql -U postgres -d pharmacy_db -f database/schema.sql",
    "db:seed": "psql -U postgres -d pharmacy_db -f database/seed.sql",
    "db:add-auth": "psql -U postgres -d pharmacy_db -f database/add_authentication.sql",
    "db:add-medicine-images": "psql -U postgres -d pharmacy_db -f database/add_medicine_images.sql",
    "db:add-purchases": "psql -U postgres -d pharmacy_db -f database/add_purchases.sql",
    "db:update-purchase-statuses": "psql -U postgres -d pharmacy_db -f database/update_purchase_statuses.sql",
    "db:add-purchase-denial-details": "psql -U postgres -d pharmacy_db -f database/add_purchase_denial_details.sql"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
